# ============================================
# RL-Legged-Locomotion .gitignore
# ============================================

# --- Python ---
venv/
env/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/

# --- ML-Agents Training Outputs ---
results/
!results/backups/
!results/backups/**
summaries/
models/
*.onnx
!Assets/**/*.onnx
run_logs/

# --- Reference Clone (huge, don't commit) ---
ml-agents-release/
ml-agents/

# --- Unity Generated Folders ---
UnityProject/[Ll]ibrary/
UnityProject/[Tt]emp/
UnityProject/[Oo]bj/
UnityProject/[Bb]uild/
UnityProject/[Bb]uilds/
UnityProject/[Ll]ogs/
UnityProject/[Uu]ser[Ss]ettings/
UnityProject/[Mm]emoryCaptures/
UnityProject/[Aa]ssets/AssetStoreTools*
UnityProject/[Aa]ssets/Plugins/Editor/JetBrains*

# Also catch them at root level (in case Unity project sits at root)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# --- Unity Auto-Generated Files ---
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# --- Unity Builds ---
*.apk
*.aab
*.unitypackage
*.app

# --- Unity Crash Reports ---
sysinfo.txt
crashlytics-build.properties

# --- IDE / Editors ---
.vs/
.vscode/
.idea/
*.swp
*.swo
*~

# --- Rider ---
.idea/
*.sln.iml

# --- OS Files ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
$RECYCLE.BIN/

# --- Misc ---
*.log
*.bak
*.tmp
node_modules/

# --- Keep these (overrides above) ---
!.gitignore
!.gitkeep
!README.md